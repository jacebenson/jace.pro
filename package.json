{
  "scripts": {
    "start": "npm-run-all --parallel css eleventy browsersync",
    "dev": "npm run build && eleventy --watch --serve",
    "dev:hot": "cross-env ELEVENTY_ENV=development eleventy --watch --serve --quiet",
    "dev2": "npm-run-all --parallel css eleventy",
    "eleventy": "eleventy --watch --serve",
    "debug": "set DEBUG=* & eleventy",
    "css": "postcss src/static/css/tailwind.css --o _site/static/css/style.css --watch",
    "build": "cross-env NODE_ENV=production eleventy && cross-env NODE_ENV=production tailwindcss -i src/static/css/tailwind.css -o _site/static/css/style.css",
    "browsersync": "browser-sync start --server '_site' --files '_site' --port 8080 --no-notify --no-open",
    "localgit": "npx netlify-cms-proxy-server"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-plugin-rss": "^2.0.4",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@resoc/eleventy-plugin-social-image": "^0.0.4",
    "@resoc/netlify-plugin-social-image": "^0.0.9",
    "@tailwindcss/typography": "^0.5.19",
    "alpinejs": "^3.15.0",
    "browser-sync": "^2.29.3",
    "chokidar": "^3.6.0",
    "cross-env": "^7.0.3",
    "html-minifier": "^4.0.0",
    "js-yaml": "^4.1.0",
    "luxon": "^3.7.2",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "npm-run-all": "^4.1.5",
    "postcss-cli": "^10.1.0",
    "prismjs": "^1.30.0",
    "tailwindcss": "^3.4.18"
  },
  "dependencies": {
    "@vidhill/fortawesome-brands-11ty-shortcode": "^1.1.0",
    "@vidhill/fortawesome-free-regular-11ty-shortcode": "^1.0.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6"
  }
}
